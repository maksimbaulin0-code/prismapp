{
  "name": "beauty-marketplace",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server.ts",
    "dev:all": "concurrently -n vite,api -c blue,green \"npm run dev\" \"npm run dev:server\"",
